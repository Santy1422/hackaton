# Postgres de prod (Railway)
DATABASE_URL=postgresql://postgres:PASSWORD@shortline.proxy.rlwy.net:32375/railway

# Auth
JWT_SECRET=change-me-in-prod
JWT_EXPIRE_HOURS=12

# CORS — orígenes del frontend permitidos (coma-separados). En prod: la URL del front.
CORS_ORIGINS=http://localhost:5173

# Claude (informes narrados por Sonnet) — opcional; sin esto usa fallback determinista
ANTHROPIC_API_KEY=

# Zavu — WhatsApp. Sin ZAVU_API_KEY hace dry-run.
ZAVU_API_KEY=
ZAVU_SENDER=kd7evvzpnt76thf9r9gs8yh4hx86cb1x
# Destinatarios de los crons (E.164, coma-separados)
ZAVU_RECIPIENTS=

# Crons de WhatsApp (APScheduler): weekly=lun 08:00 · monthly=dia1 08:00 · covenant=cada hora
ENABLE_SCHEDULER=0
SCHEDULER_TZ=Europe/Amsterdam
# URL publica del PDF para el informe mensual (opcional)
PUBLIC_REPORT_URL=
# Secreto para verificar x-zavu-signature del webhook (vacío = sin verificar, dev)
ZAVU_WEBHOOK_SECRET=
ZAVU_TEMPLATE_ID=
ZAVU_WHATSAPP_NUMBER=+15559919064
